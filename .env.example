# ─────────────────────────────────────────────
# tap.connect — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# 1. Supabase — https://app.supabase.com
#    Your Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# 2. Anthropic Claude API — https://console.anthropic.com
#    API Keys → Create new secret key
#    (optional for v1 — app works without it, uses smart fallback)
VITE_ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
